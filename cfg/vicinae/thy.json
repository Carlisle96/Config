{
  "font": {
    "normal": {
      "family": "Hasklug Nerd Font Propo"
    }
  },
  "theme": {
    "dark": {
      "name": "thy",
      "icon_theme": "Newaita-reborn-deep-purple-dark"
    }
  },
  "launcher_window": {
    "opacity": 1,
    "client_side_decorations": {
      "enabled": true
    }
  },
  "providers": {
    "browser-extension": {
      "enabled": false
    },
    "core": {
      "entrypoints": {
        "keybind-settings": {
          "enabled": false
        },
        "sponsor": {
          "enabled": false
        }
      }
    },
    "developer": {
      "enabled": false
    },
    "font": {
      "entrypoints": {
        "browse": {
          "enabled": false
        }
      }
    },
    "power": {
      "entrypoints": {
        "lock": {
          "preferences": {
            "customProgram": "/usr/bin/hyprlock"
          }
        }
      }
    },
    "system": {
      "entrypoints": {
        "run": {
          "preferences": {
            "default-action": "run"
          }
        }
      }
    },
    "theme": {
      "entrypoints": {
        "set": {
          "enabled": false
        }
      }
    },
    "wm": {
      "entrypoints": {
        "switch-windows": {
          "enabled": false
        }
      }
    }
  }
}
