#!/usr/bin/env bash

set -Eeuo pipefail

mode=${1:-compact}

is_open() {
  eww active-windows 2>/dev/null | grep -Eq "^[^:]+: $1$"
}

case "$mode" in
  compact)
    eww close achievements-full >/dev/null 2>&1 || true
    if ! is_open achievements; then
      eww open achievements
    fi
    ;;
  full)
    eww close achievements >/dev/null 2>&1 || true
    if ! is_open achievements-full; then
      eww open achievements-full
    fi
    ;;
  *)
    echo "Usage: ${0##*/} compact|full" >&2
    exit 2
    ;;
esac
