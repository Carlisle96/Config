#!/usr/bin/env bash

set -Eeuo pipefail

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/thyachieve"

lookup_tsv() {
  local input=$1
  local table=$2
  local result_threshold="0"
  local result_value="0"
  local threshold value

  input=${input%.*}

  while IFS=$'\t' read -r threshold value; do
    if (( input >= threshold )); then
      result_threshold=$threshold
      result_value=$value
    else
      break
    fi
  done < "$table"

  printf '%s\t%s\n' "$result_threshold" "$result_value"
}

roman_numeral() {
  local number=$1
  local result=""
  local values=(1000 900 500 400 100 90 50 40 10 9 5 4 1)
  local numerals=(M CM D CD C XC L XL X IX V IV I)
  local i

  if (( number <= 0 )); then
    printf 'O\n'
    return
  fi

  for i in "${!values[@]}"; do
    while (( number >= values[i] )); do
      result+="${numerals[i]}"
      number=$(( number - values[i] ))
    done
  done

  printf '%s\n' "$result"
}

worked_hours_last_30_days() {
  local from to seconds

  from=$(date -d "30 days ago" +%F)
  to=$(date +%F)
  seconds=$(
    watson report -c -j -f "$from" -t "$to" \
      | jq -r '.time | floor'
  )

  printf '%s\n' "$(( seconds / 3600 ))"
}

worked_hours=$(worked_hours_last_30_days)
IFS=$'\t' read -r _ work < <(
  lookup_tsv "$worked_hours" "${CONFIG_DIR}/work.tsv"
)

eww update \
  "work=$work" \
  "work_roman=$(roman_numeral "$work")" \
  "work_hours_roman=$(roman_numeral "$worked_hours")"
