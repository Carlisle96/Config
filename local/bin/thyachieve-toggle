#!/usr/bin/env bash

set -Eeuo pipefail

lock_file="${XDG_RUNTIME_DIR:-/tmp}/thyachieve-toggle.lock"
exec 9>"$lock_file"
flock -n 9 || exit 0

eww_cmd() {
  eww "$@" 9>&-
}

current=$(eww_cmd get active_display 2>/dev/null || printf '%s\n' compact)

case "$current" in
  full)
    eww_cmd update active_display=compact
    ;;
  *)
    eww_cmd update active_display=full
    ;;
esac
