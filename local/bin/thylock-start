#!/usr/bin/env bash

set -Eeuo pipefail

if ! command -v hyprlock >/dev/null 2>&1
then
  logger -t thylock-start "hyprlock is missing; exiting Hyprland instead of exposing an unlocked session"
  hyprctl dispatch exit 1 >/dev/null 2>&1 || true
  exit 127
fi

exec hyprlock \
  --config "${XDG_CONFIG_HOME:-$HOME/.config}/hypr/hyprlock-startup.conf" \
  --immediate-render \
  --no-fade-in
