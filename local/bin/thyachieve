#!/usr/bin/env bash

set -Eeuo pipefail

WINDOW="achievements"
START_DATE="2026-05-26"
CUTOFF_HOUR="20"
DAYS=(1 2 3 4 5 7 10 14 21 28 35 42 50 60 70 84 100 120 150 180 210 240 270 310 365)
PROGRESSIONS=(11 12 13 14 15 21 22 23 24 25 31 32 33 34 35 41 42 43 44 45 51 52 53 54 55)

effective_date() {
  local now cutoff
  now=$(date +%s)
  cutoff=$(date -d "$(date +%F) ${CUTOFF_HOUR}:00" +%s)

  if (( now >= cutoff )); then
    date +%F
  else
    date -d "yesterday" +%F
  fi
}

lookup_progression() {
  local daysAfterStart=$1
  local prog="0"
  local i

  for i in "${!DAYS[@]}"; do
    if (( daysAfterStart >= DAYS[i] )); then
      prog=${PROGRESSIONS[i]}
    else
      break
    fi
  done

  printf '%s\n' "$prog"
}

days_since_start() {
  local date_key=$1
  local start_date=$2
  local date_epoch start_epoch

  date_epoch=$(date -d "$date_key" +%s)
  start_epoch=$(date -d "$start_date" +%s)
  printf '%s\n' "$(( (date_epoch - start_epoch) / 86400 ))"
}

date_key=$(effective_date)
days_after_start=$(days_since_start "$date_key" "$START_DATE")
progression=$(lookup_progression "$days_after_start")
eww open "$WINDOW" --arg "progression=$progression"
