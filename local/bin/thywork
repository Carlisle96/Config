#!/usr/bin/env bash

set -Eeuo pipefail

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/thyachieve"

print_state() {
  local text=$1
  local class=$2
  local percentage=$3
  local worked_today_f=$4
  local worked_this_month_f=$5
  local normalized_month_hours=$6

  printf '{"text":"%s","class":"%s","percentage":%s,"tooltip":"󰖙  :: %s\\n󰽥  :: %s\\n󰽢  :: %s h"}\n' \
    "$text" "$class" "$percentage" \
    "$worked_today_f" "$worked_this_month_f" "$normalized_month_hours"
}

print_time() {
  local secs=$1
  local class=$2
  local percentage=$3
  local worked_today_f=$4
  local worked_this_month_f=$5
  local normalized_month_hours=$6

  local formatted
  formatted=$(format_duration "$secs")
  print_state "\\n${formatted}" "$class" "$percentage" \
    "$worked_today_f" "$worked_this_month_f" "$normalized_month_hours"
}

format_duration() {
  local secs=$1
  local hours=$(( secs / 3600 ))
  local minutes=$(( secs % 3600 / 60 ))

  printf '%d:%02d' "$hours" "$minutes"
}

watson_time() {
  watson report "$@" -c -j | jq -r '.time | floor'
}

lookup_thresholds() {
  local worked_secs=$1
  local current=0
  local next=0
  local threshold _reward
  local threshold_secs

  while IFS=$'\t' read -r threshold _reward; do
    threshold_secs=$(( threshold * 3600 ))
    next=$threshold_secs

    if (( worked_secs < threshold_secs )); then
      printf '%s\t%s\n' "$current" "$next"
      return
    fi

    current=$threshold_secs
  done < "${CONFIG_DIR}/work.tsv"

  printf '%s\t%s\n' "$current" "$current"
}

last_threshold_secs() {
  local threshold _reward
  local last=0

  while IFS=$'\t' read -r threshold _reward; do
    last=$threshold
  done < "${CONFIG_DIR}/work.tsv"

  printf '%s\n' "$(( last * 3600 ))"
}

rolling_from=$(date -d "30 days ago" +%F)
worked_rolling=$(watson_time -f "$rolling_from")

IFS=$'\t' read -r _current_threshold_secs next_threshold_secs < <(
  lookup_thresholds "$worked_rolling"
)
final_threshold_secs=$(last_threshold_secs)

work_per_day=$(( next_threshold_secs / 30 ))
solid_per_day=$(( next_threshold_secs / 20 ))
done_per_day=$(( next_threshold_secs / 15 ))
worked_today=$(watson_time -d)
worked_this_month=$(watson_time -m)
day_of_month=$(date +%-d)
normalized_month_hours=$(( worked_this_month * 30 / day_of_month / 3600 ))

worked_today_f=$(format_duration "$worked_today")
worked_this_month_f=$(format_duration "$worked_this_month")

# Minimum work time
left_today=$(( work_per_day - worked_today ))
if (( left_today > 0 )); then
    print_time "$left_today" 'behind' 0 "$worked_today_f" "$worked_this_month_f" "$normalized_month_hours"
    exit 0
fi

# Solid work day
solid_left=$(( solid_per_day - worked_today ))
if (( solid_left > 0 )); then
    print_time "$solid_left" 'solid' 35 "$worked_today_f" "$worked_this_month_f" "$normalized_month_hours"
    exit 0
fi

# Solid reached, final daily target still open
done_left=$(( done_per_day - worked_today ))
if (( done_left > 0 )); then
    print_time "$worked_today" 'checked' 65 "$worked_today_f" "$worked_this_month_f" "$normalized_month_hours"
    exit 0
fi

# Done for today
print_state "" 'ahead' 100 "$worked_today_f" "$worked_this_month_f" "$normalized_month_hours"
