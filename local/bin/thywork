#!/usr/bin/env bash

set -Eeuo pipefail

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/thyachieve"

print_time() {
  local secs=$1
  local class=$2
  local percentage=$3

  local formatted
  formatted=$(format_duration "$secs")
  printf '{"text":"%s","class":"%s","percentage":%s,"tooltip":"day : %s\\nmonth : %s"}\n' \
    "$formatted" "$class" "$percentage" "$worked_today_formatted" "$worked_this_month_formatted"
}

format_duration() {
  local secs=$1
  local hours=$(( secs / 3600 ))
  local minutes=$(( secs % 3600 / 60 ))

  printf '%d:%02d' "$hours" "$minutes"
}

watson_time() {
  watson report "$@" -c -j | jq -r '.time | floor'
}

lookup_work_thresholds() {
  local worked_hours=$1
  local previous=0
  local current=0
  local next=0
  local threshold _reward

  while IFS=$'\t' read -r threshold _reward; do
    [[ -z ${threshold:-} || ${threshold:0:1} == "#" ]] && continue

    if (( worked_hours >= threshold )); then
      previous=$current
      current=$threshold
    elif (( next == 0 )); then
      next=$threshold
      break
    fi
  done < "${CONFIG_DIR}/work.tsv"

  printf '%s\t%s\t%s\n' "$previous" "$current" "$next"
}


rolling_from=$(date -d "30 days ago" +%F)
month_from=$(date +%Y-%m-01)

worked_today=$(watson_time -d)
worked_this_month=$(watson_time -f "$month_from")
worked_today_formatted=$(format_duration "$worked_today")
worked_this_month_formatted=$(format_duration "$worked_this_month")
worked_rolling=$(watson_time -f "$rolling_from")
worked_morning=$(( worked_rolling - worked_today ))
worked_morning_hours=$(( worked_morning / 3600 ))

IFS=$'\t' read -r previous_threshold current_threshold next_threshold < <(
  lookup_work_thresholds "$worked_morning_hours"
)

(( current_threshold == 0 )) && current_threshold=45
(( previous_threshold == 0 )) && previous_threshold=45

work_per_day=$(( current_threshold * 3600 / 30 ))
previous_work_per_day=$(( previous_threshold * 3600 / 30 ))

left_today=$(( work_per_day - worked_today ))

if (( left_today > 0 )); then
  print_time "$left_today" 'behind' 0
  exit 0
fi

defend_goal=$(( work_per_day + previous_work_per_day ))
defend_left=$(( defend_goal - worked_today ))

if (( next_threshold > 0 )); then
  next_reward_left=$(( next_threshold * 3600 - worked_rolling ))
else
  next_reward_left=0
fi

if (( defend_left > 0 && next_reward_left > 0 )); then
  if (( next_reward_left <= defend_left )); then
    print_time "$next_reward_left" 'reward' 65
  else
    print_time "$defend_left" 'catchup' 35
  fi
  exit 0
fi

if (( defend_left > 0 )); then
  print_time "$defend_left" 'catchup' 35
  exit 0
fi

if (( next_reward_left > 0 )); then
  print_time "$next_reward_left" 'reward' 65
  exit 0
fi

if (( next_threshold > 0 )); then
  next_work_per_day=$(( next_threshold * 3600 / 30 ))

  if (( worked_today < next_work_per_day * 2 && defend_left > 0 )); then
    print_time "$defend_left" 'catchup' 35
    exit 0
  fi

  buffer_base=$(( next_threshold * 3600 ))
else
  buffer_base=$(( current_threshold * 3600 ))
fi

buffer=$(( worked_rolling - buffer_base ))
print_time "$buffer" 'ahead' 100
