#!/usr/bin/env bash

set -Eeuo pipefail

work_per_day=$((90 * 60))
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/thyachieve"

print_time() {
  local secs=$1
  local class=$2
  local percentage=$3

  local formatted
  formatted=$(date -u -d "@$secs" +"%-H:%M")
  printf '{"text":"%s","class":"%s","percentage":%s}\n' "$formatted" "$class" "$percentage"
}

watson_time() {
  watson report "$@" -c -j | jq -r '.time | floor'
}

lookup_work_thresholds() {
  local worked_hours=$1
  local current=0
  local next=0
  local threshold reward

  while IFS=$'\t' read -r threshold reward; do
    [[ -z ${threshold:-} || ${threshold:0:1} == "#" ]] && continue

    if (( worked_hours >= threshold )); then
      current=$threshold
    elif (( next == 0 )); then
      next=$threshold
      break
    fi
  done < "${CONFIG_DIR}/work.tsv"

  printf '%s\t%s\n' "$current" "$next"
}


worked_today=$(watson_time -d)
left_today=$(( work_per_day - worked_today ))

# 1. Ziel: Tagesziel schaffen
if (( left_today > 0 )); then
  print_time "$left_today" 'behind' 0
  exit 0
fi

rolling_from=$(date -d "30 days ago" +%F)
tomorrow_from=$(date -d "29 days ago" +%F)

worked_rolling=$(watson_time -f "$rolling_from")
worked_tomorrow_window=$(watson_time -f "$tomorrow_from")
worked_rolling_hours=$(( worked_rolling / 3600 ))

IFS=$'\t' read -r current_threshold next_threshold < <(
  lookup_work_thresholds "$worked_rolling_hours"
)

if (( current_threshold > 0 )); then
  keep_current_left=$(( current_threshold * 3600 - worked_tomorrow_window ))

  if (( keep_current_left > 0 )); then
    print_time "$keep_current_left" 'catchup' 35
    exit 0
  fi
fi

if (( next_threshold > 0 )); then
  next_reward_left=$(( next_threshold * 3600 - worked_rolling ))
  print_time "$next_reward_left" 'reward' 65
  exit 0
fi

printf '{"text":"","class":"ahead","percentage":100}\n'
