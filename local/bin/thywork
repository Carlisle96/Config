#!/usr/bin/env bash

set -Eeuo pipefail

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/thyachieve"

print_time() {
  local secs=$1
  local class=$2
  local percentage=$3

  local formatted
  formatted=$(format_duration "$secs")
  printf '{"text":"%s","class":"%s","percentage":%s,"tooltip":"ó°–™ : %s\\nó°’˜ : %s\\nó°½¥ : %s"}\n' \
    "$formatted" "$class" "$percentage" \
    "$worked_today_formatted" "$defend_formatted" "$worked_this_month_formatted"
}

format_duration() {
  local secs=$1
  local hours=$(( secs / 3600 ))
  local minutes=$(( secs % 3600 / 60 ))

  printf '%d:%02d' "$hours" "$minutes"
}

watson_time() {
  watson report "$@" -c -j | jq -r '.time | floor'
}

lookup_work_thresholds() {
  local worked_hours=$1
  local current=0
  local maximum=0
  local threshold _reward

  while IFS=$'\t' read -r threshold _reward; do
    [[ -z ${threshold:-} || ${threshold:0:1} == "#" ]] && continue

    maximum=$threshold

    if (( worked_hours >= threshold )); then
      current=$threshold
    fi
  done < "${CONFIG_DIR}/work.tsv"

  printf '%s\t%s\n' "$current" "$maximum"
}

lookup_next_threshold() {
  local worked_secs=$1
  local threshold _reward

  while IFS=$'\t' read -r threshold _reward; do
    [[ -z ${threshold:-} || ${threshold:0:1} == "#" ]] && continue

    if (( worked_secs < threshold * 3600 )); then
      printf '%s\n' "$threshold"
      return
    fi
  done < "${CONFIG_DIR}/work.tsv"

  printf '0\n'
}


rolling_from=$(date -d "30 days ago" +%F)
month_from=$(date +%Y-%m-01)

worked_today=$(watson_time -d)
worked_this_month=$(watson_time -f "$month_from")
worked_today_formatted=$(format_duration "$worked_today")
worked_this_month_formatted=$(format_duration "$worked_this_month")
worked_rolling=$(watson_time -f "$rolling_from")
worked_falling_off=$(watson_time -f "$rolling_from" -t "$rolling_from")
worked_morning_hours=$(( (worked_rolling - worked_today) / 3600 ))
next_threshold=$(lookup_next_threshold "$worked_rolling")

if (( next_threshold > 0 )); then
  next_ribbon_left=$(( next_threshold * 3600 - worked_rolling ))
else
  next_ribbon_left=0
fi

IFS=$'\t' read -r current_threshold maximum_threshold < <(
  lookup_work_thresholds "$worked_morning_hours"
)

(( current_threshold == 0 )) && current_threshold=45

IFS=$'\t' read -r held_threshold _maximum_threshold < <(
  lookup_work_thresholds "$(( worked_rolling / 3600 ))"
)

if (( held_threshold > 0 )); then
  defend_left=$(( held_threshold * 3600 + worked_falling_off - worked_rolling ))
else
  defend_left=0
fi

if (( defend_left > 0 )); then
  defend_formatted=$(format_duration "$defend_left")
else
  defend_formatted='ó°„¬'
fi

work_per_day=$(( current_threshold * 3600 / 30 ))
maximum_work_per_day=$(( maximum_threshold * 3600 / 30 ))

left_today=$(( work_per_day - worked_today ))

if (( left_today > 0 )); then
  print_time "$left_today" 'behind' 0
  exit 0
fi

left_maximum=$(( maximum_work_per_day - worked_today ))

if (( left_maximum > 0 )); then
  print_time "$left_maximum" 'catchup' 0
  exit 0
fi

print_time "$next_ribbon_left" 'ahead' 100
